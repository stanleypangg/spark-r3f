{
  "name": "spark-r3f",
  "version": "0.1.0",
  "description": "Gaussian splatting for React Three Fiber; a tiny wrapper around @sparkjsdev/spark that fixes demand-mode rendering.",
  "license": "MIT",
  "author": "Stanley Pang <stanleypang666@gmail.com>",
  "keywords": [
    "react",
    "three",
    "r3f",
    "react-three-fiber",
    "gaussian-splatting",
    "spark",
    "splat",
    "3d"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.180",
    "@react-three/fiber": ">=8",
    "@sparkjsdev/spark": ">=2.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@react-three/fiber": "^9.2.0",
    "@sparkjsdev/spark": "^2.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.180.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.180.0",
    "tsup": "^8.3.5",
    "typescript": "~5.8.3"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "example": "npm --prefix examples run dev",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
